rules_version = '2';

// ============================================================
//  Reglas de seguridad de Firestore — Blackjack 21
//  Fuente de verdad: docs/arquitectura/seguridad.md
//
//  Principio: el cliente NUNCA escribe dinero (balance) ni el
//  estado del juego (games) ni las transacciones. Eso lo hacen
//  las Cloud Functions con el Admin SDK (que ignora estas reglas).
//
//  NOTA: versión actualizada en Fase 4 (social).
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function autenticado() {
      return request.auth != null;
    }

    function esDueno(uid) {
      return autenticado() && request.auth.uid == uid;
    }

    // ¿El usuario actual es amigo ACEPTADO de `uid`?
    function esAmigoDe(uid) {
      let ref = /databases/$(database)/documents/friendships/$(uid)/contacts/$(request.auth.uid);
      return autenticado() &&
        exists(ref) &&
        get(ref).data.status == 'accepted';
    }

    // ¿La escritura mantiene intactos los campos que solo las Functions pueden tocar?
    function noTocaCamposProtegidos() {
      return request.resource.data.balance == resource.data.balance &&
        request.resource.data.lastAdReward == resource.data.lastAdReward &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['conversionBonusGranted', 'isAnonymous']);
    }

    // ---------- users ----------
    match /users/{uid} {
      // Lee el dueño y sus amigos aceptados.
      allow read: if esDueno(uid) || esAmigoDe(uid);

      // La creación del perfil y el saldo inicial los hace la Function onUserCreate.
      // En Fase 3/4, el cliente crea el perfil directamente (workaround hasta que
      // esté habilitado el plan Blaze y desplegada la Function).
      // Se fuerza balance == 1000. Si el cliente incluye isAnonymous, debe coincidir
      // con el estado real del token Auth (evita fraud del bono de conversión).
      // Si no lo incluye, se permite (workaround legacy sin el campo).
      // NOTA: este workaround debe eliminarse cuando onUserCreate esté desplegada.
      allow create: if esDueno(uid)
        && request.resource.data.balance == 1000
        && !request.resource.data.keys().hasAny(['conversionBonusGranted'])
        && (!request.resource.data.keys().hasAny(['isAnonymous'])
             || request.resource.data.isAnonymous
                  == (request.auth.token.firebase.sign_in_provider == 'anonymous'));

      // El dueño actualiza su perfil, pero NO balance ni lastAdReward.
      allow update: if esDueno(uid) && noTocaCamposProtegidos();

      allow delete: if false;

      // Historial de movimientos: solo lo lee el dueño; lo escriben las Functions.
      match /transactions/{txId} {
        allow read: if esDueno(uid);
        allow write: if false;
      }
    }

    // ---------- invite_codes ----------
    // Lookup-table de códigos de invitación. Cualquier usuario autenticado puede
    // buscar un código; solo el dueño puede crear el suyo.
    match /invite_codes/{code} {
      allow read: if autenticado();
      allow create: if autenticado() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------- friendships ----------
    // Modelo bilateral: friendships/{uid}/contacts/{friendUid}.
    // Cada usuario gestiona su propio lado; las reglas extendidas permiten
    // que el otro usuario escriba en operaciones bilaterales (batch) desde el cliente.
    match /friendships/{uid}/contacts/{friendUid} {
      allow read: if esDueno(uid);

      // Crear: el dueño gestiona su lista, O el friendUid añade una solicitud pendiente
      // en el lado del uid (necesario para el batch write de enviarSolicitud).
      allow create: if esDueno(uid) ||
        (autenticado() && request.auth.uid == friendUid &&
         request.resource.data.status == 'pending' &&
         request.resource.data.initiatedBy == request.auth.uid);

      // Actualizar: el dueño actualiza su lado, O el friendUid acepta una solicitud
      // que él NO inició (es decir, B acepta la solicitud de A en el lado de A).
      // affectedKeys garantiza que solo se modifiquen status y since, no otros campos.
      allow update: if esDueno(uid) ||
        (autenticado() && request.auth.uid == friendUid &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'accepted' &&
         resource.data.initiatedBy != request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'since']));

      // Eliminar: cualquiera de los dos puede borrar (rechazar / cancelar / romper).
      allow delete: if esDueno(uid) ||
        (autenticado() && request.auth.uid == friendUid);
    }

    // ---------- rooms ----------
    match /rooms/{roomId} {
      function esMiembro() {
        return autenticado() && request.auth.uid in resource.data.players;
      }
      function esHost() {
        return autenticado() && request.auth.uid == resource.data.hostUid;
      }

      // El write toca solo el mapa players y solo la entrada del propio uid.
      // Bloqueado durante 'playing': en esa fase las acciones (apuesta/ready)
      // las gestionan las Cloud Functions sobre games/, no el cliente.
      // Dos casos válidos: (a) el jugador sale (borra su propia entrada), o
      // (b) edita su entrada sin cambiar rol (isSpectator) ni asiento (seat),
      // para que un espectador no pueda colarse como jugador activo.
      function soloActualizaSuJugador() {
        let uid = request.auth.uid;
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        let antes = resource.data.players[uid];
        let despues = request.resource.data.players[uid];
        return changed.hasOnly(['players']) &&
          resource.data.status != 'playing' &&
          request.resource.data.players.diff(resource.data.players)
            .affectedKeys().hasOnly([uid]) &&
          (
            !(uid in request.resource.data.players) ||
            (despues.isSpectator == antes.isSpectator &&
             despues.seat == antes.seat)
          );
      }

      // ¿El write agrega al propio uid en players sin tocar nada más?
      // Solo se permite si la sala está en waiting/betting y hay asientos libres.
      function seUneSolo() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        let currentSize = resource.data.players.size();
        return changed.hasOnly(['players']) &&
          !(request.auth.uid in resource.data.players) &&
          request.resource.data.players.diff(resource.data.players)
            .affectedKeys().hasOnly([request.auth.uid]) &&
          currentSize < resource.data.maxPlayers &&
          (resource.data.status == 'waiting' || resource.data.status == 'betting');
      }

      // Salas públicas las ve cualquiera autenticado; las privadas, solo miembros.
      allow read: if autenticado() && (resource.data.private == false || esMiembro());

      // El host crea su sala (hostUid debe coincidir con el caller).
      allow create: if autenticado() && request.resource.data.hostUid == request.auth.uid;

      // El host puede actualizar cualquier campo.
      // Los miembros solo pueden actualizar su propia entrada en players.
      // Cualquier usuario autenticado puede unirse (seUneSolo).
      allow update: if esHost() || (esMiembro() && soloActualizaSuJugador()) || (autenticado() && seUneSolo());

      allow delete: if esHost();

      // Chat: lo leen y escriben los miembros; el autor debe ser uno mismo.
      match /chat/{msgId} {
        allow read: if autenticado() &&
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.players;
        allow create: if autenticado() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ---------- games ----------
    // El reparto, las acciones y la resolución los hacen las Functions (anti-trampa).
    // Los clientes pueden leer el estado público de la partida (sin el shoe).
    match /games/{gameId} {
      allow read: if autenticado() &&
        request.auth.uid in resource.data.players;
      allow write: if false;

      // El shoe y el estado del server son solo para Functions (Admin SDK).
      match /serverData/{doc} {
        allow read: if false;
        allow write: if false;
      }
    }
  }
}
