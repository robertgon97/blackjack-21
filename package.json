  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/robertgon97/blackjack-21/issues"
  },
  "homepage": "https://github.com/robertgon97/blackjack-21#readme",
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
